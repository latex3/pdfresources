\bookmark[dest=blub]{vphantom:  \vphantom{unvisible}}
\bookmark[dest=blub]{emph, em:  \emph{emphasize}, \em emphasize}
\bookmark[dest=blub]{textit, itshape:  \textit{italic}, \itshape italic}
\bookmark[dest=blub]{normalfont, Huge:  \normalfont normal, \Huge huge}
\bookmark[dest=blub]{mathversion: \mathversion{bold} $\int a=b$}
